---
// COMPONENTS
import Logo from "@/components/Logo.astro";

// DATA
import { navData } from "@/data/navData";
import { baseData } from "@/data/siteData";

// STATE
const year = new Date().getFullYear();
const telHref = `tel:${baseData.phone.replace(/[^\d+]/g, "")}`;
const socials = Object.entries(baseData.social ?? {}).filter(([, url]) => Boolean(url)) as [
  string,
  string,
][];

// Brand glyphs for any platforms supplied in baseData.social
const socialIcons: Record<string, string> = {
  facebook:
    "M9.1 21.5v-7.3H6.6V11h2.5V8.8c0-2.5 1.5-3.8 3.7-3.8 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.5V11h2.7l-.4 3.2h-2.3v7.3z",
  instagram:
    "M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4a3.8 3.8 0 0 1-1.4-.9 3.8 3.8 0 0 1-.9-1.4c-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4 1.3-.1 1.7-.1 4.9-.1Zm0 3.4a6.4 6.4 0 1 0 0 12.8 6.4 6.4 0 0 0 0-12.8Zm0 10.6a4.2 4.2 0 1 1 0-8.4 4.2 4.2 0 0 1 0 8.4Zm6.6-10.9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z",
  x: "M17.5 3h3l-6.6 7.5L21.7 21h-6l-4.7-6.1L5.6 21H2.5l7-8L2.3 3h6.1l4.3 5.6L17.5 3Zm-1 16h1.7L7.6 4.8H5.8z",
  twitter: "M17.5 3h3l-6.6 7.5L21.7 21h-6l-4.7-6.1L5.6 21H2.5l7-8L2.3 3h6.1l4.3 5.6L17.5 3Zm-1 16h1.7L7.6 4.8H5.8z",
  tiktok:
    "M16.5 3c.3 2.1 1.7 3.7 3.7 3.9v2.6c-1.2.1-2.4-.2-3.5-.8v5.7a5.7 5.7 0 1 1-5.7-5.7c.3 0 .6 0 .9.1v2.7a3 3 0 1 0 2.1 2.9V3h2.5Z",
  youtube:
    "M22 12s0-2.9-.4-4.3a2.7 2.7 0 0 0-1.9-1.9C18.2 5.4 12 5.4 12 5.4s-6.2 0-7.7.4a2.7 2.7 0 0 0-1.9 1.9C2 9.1 2 12 2 12s0 2.9.4 4.3a2.7 2.7 0 0 0 1.9 1.9c1.5.4 7.7.4 7.7.4s6.2 0 7.7-.4a2.7 2.7 0 0 0 1.9-1.9C22 14.9 22 12 22 12Zm-12 2.8V9.2l4.8 2.8z",
  linkedin:
    "M6.9 8.8H3.7V20h3.2zM5.3 3.6a1.9 1.9 0 1 0 0 3.8 1.9 1.9 0 0 0 0-3.8ZM20.3 20v-6.1c0-3.3-1.8-4.8-4.1-4.8a3.6 3.6 0 0 0-3.2 1.8V9.2H9.7V20h3.2v-5.6c0-1.5.3-2.9 2.1-2.9s1.9 1.7 1.9 3V20z",
};
---

<footer aria-label="Site footer">
  <div class="container container-md">
    <div class="foot-top">
      <div class="foot-brand">
        <Logo />
        <p class="blurb">
          Hand-coded websites for local businesses in and around Monroe, North Carolina. Proudly
          serving Monroe, Waxhaw, Matthews, Charlotte, and surrounding areas.
        </p>
        {
          socials.length > 0 && (
            <div class="foot-social">
              {socials.map(([name, url]) => (
                <a href={url} target="_blank" rel="noopener noreferrer" aria-label={name}>
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={socialIcons[name.toLowerCase()] ?? socialIcons.x} />
                  </svg>
                </a>
              ))}
            </div>
          )
        }
      </div>

      <div class="foot-cols">
        <div class="foot-col">
          <span class="ft">Site</span>
          <nav class="links" aria-label="Footer navigation">
            {navData.map(i => <a href={i.href}>{i.title}</a>)}
          </nav>
        </div>
        <div class="foot-col">
          <span class="ft">Get in touch</span>
          <div class="links">
            <a href={telHref}>{baseData.phone}</a>
            <a href={`mailto:${baseData.email}`}>{baseData.email}</a>
          </div>
        </div>
      </div>
    </div>

    <div class="foot-bottom">
      <span class="fb-copy">© {year} Beyond Belief Web Design. All rights reserved.</span>
      <nav class="foot-legal" aria-label="Legal">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms-and-conditions">Terms &amp; Conditions</a>
        <a href="/accessibility">Accessibility</a>
      </nav>
    </div>
  </div>
</footer>

<style lang="scss">
  footer {
    position: relative;
    overflow: hidden;
    padding: clamp(56px, 7vw, 96px) 0 44px;
    color: var(--paper);
    background: var(--ink-900);
    border-top: 1px solid var(--ink-600);
  }

  .foot-top {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
    justify-content: space-between;
    align-items: flex-start;
  }

  .foot-brand {
    max-width: 360px;
  }

  .blurb {
    margin: 18px 0 0;
    max-width: 340px;
    font: 400 0.9375rem/1.55 var(--font-body);
    color: var(--stone-300);
  }

  .foot-social {
    display: flex;
    gap: 10px;
    margin-top: 20px;

    a {
      display: grid;
      place-items: center;
      width: 38px;
      height: 38px;
      color: var(--stone-200);
      border: 1px solid var(--ink-600);
      border-radius: 50%;
      transition:
        color var(--dur),
        background var(--dur),
        border-color var(--dur);

      &:hover {
        color: var(--ink-900);
        background: var(--lime);
        border-color: var(--lime);
      }
    }

    svg {
      width: 17px;
      height: 17px;
    }
  }

  .foot-cols {
    display: flex;
    flex-wrap: wrap;
    gap: 72px;
  }

  .foot-col .ft {
    display: block;
    margin-bottom: 18px;
    font: 700 0.6875rem/1 var(--mono-family);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--stone-400);
  }

  .foot-col .links {
    display: flex;
    flex-direction: column;
    gap: 12px;

    a {
      font: 400 0.9375rem/1 var(--font-body);
      color: var(--stone-200);
      text-decoration: none;
      transition: color var(--dur);

      &:hover {
        color: var(--lime);
      }
    }
  }

  .foot-bottom {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    justify-content: space-between;
    align-items: center;
    margin-top: 52px;
    padding-top: 26px;
    border-top: 1px solid var(--ink-600);

    span {
      font: 400 0.75rem/1.5 var(--mono-family);
      color: var(--stone-400);
    }
  }

  .foot-legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    margin-left: auto;

    a {
      font: 400 0.75rem/1.5 var(--mono-family);
      color: var(--stone-400);
      text-decoration: none;
      transition: color var(--dur);

      &:hover {
        color: var(--lime);
      }
    }
  }

  @media (max-width: 768px) {
    .foot-top {
      gap: 32px;
    }
    .foot-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 18px;
    }
    .foot-legal {
      margin-left: 0;
    }
  }
</style>
