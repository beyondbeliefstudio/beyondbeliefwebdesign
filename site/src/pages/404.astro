---
import Layout from "@/layouts/Layout.astro";
import Links from "@/components/Links.astro";
import Heading from "@/components/Heading.astro";
---

<Layout
  pageTitle="Page Not Found | Beyond Belief Web Design"
  description="The page you're looking for doesn't exist. Let's get you back on track."
  hideCTA
>
  <section class="not-found" aria-label="404 Not Found">
    <div class="nf-wash" aria-hidden="true"></div>
    <div class="container container-md">
      <div class="nf-in">
        <span class="nf-code" aria-hidden="true">404</span>
        <Heading tag="h1" size="xl" fontFamily="primary" marginBottom="s" weight="fw800">
          This page wandered off.
        </Heading>
        <p>
          The page you were looking for may have been moved or deleted. Let's get you back to
          something useful.
        </p>
        <div class="btn-wrapper btn-wrapper--left">
          <Links variant="primary" href="/">
            Back to home <span class="arr" aria-hidden="true">→</span>
          </Links>
          <Links variant="secondary" href="/#contact">Get in touch</Links>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .not-found {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: 86vh;
  }
  .nf-wash {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(60% 70% at 26% 24%, rgba(204, 255, 0, 0.1), transparent 60%),
      var(--paper);
  }
  .nf-in {
    position: relative;
    z-index: 2;
    max-width: 620px;
    padding: clamp(120px, 16vh, 180px) 0 clamp(48px, 6vw, 90px);
  }
  .nf-code {
    display: block;
    margin-bottom: 8px;
    font: 800 clamp(5rem, 15vw, 10rem)/0.9 var(--font-display);
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 2px var(--stone-200);
  }
  .not-found p {
    max-width: 50ch;
    margin: 4px 0 0;
    font: 400 1.0625rem/1.6 var(--font-body);
    color: var(--fg2);
  }
</style>
