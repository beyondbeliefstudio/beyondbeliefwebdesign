---
// COMPONENTS
import Heading from "@/components/Heading.astro";

const faqs = [
  {
    q: "Do I own my domain?",
    a: "Yes, always. Your domain belongs to you and stays in your name, under your control, forever. If you already have one we will use it. If you need one I will walk you through getting it set up.",
  },
  {
    q: "What about transferring my existing domain?",
    a: "Easy. If your domain is registered somewhere like GoDaddy or Namecheap, pointing or transferring it to your new site is straightforward. I handle the technical side and walk you through anything that needs your login.",
  },
  {
    q: "Do I have to write the content myself?",
    a: "No, and I do not charge extra for it. You know your business better than anyone, so I will ask the right questions and turn your answers into copy that sounds like you and works for Google. You do not need to be a writer.",
  },
  {
    q: "What if I do not have good photos?",
    a: "No problem. If you have great photos we will use them. If you do not, or if the ones you have are not great quality, I will help generate professional looking imagery so your site still looks sharp. A lack of photos has never stopped a great website from getting built.",
  },
  {
    q: "What does the 12-month commitment mean?",
    a: "It means I ask you to stay on the plan for the first year, because building a real online presence takes time and I want to do it right. After that first year, you are completely month to month and can cancel anytime.",
  },
  {
    q: "When do you start building my site?",
    a: "Once your first payment comes through. From there my goal is always to have your site fully live before your second payment ever processes.",
  },
  {
    q: "Can I add more pages later?",
    a: "Absolutely. Additional pages are a one-time $149 each to build, and your monthly rate never changes.",
  },
  {
    q: "Is there a big upfront cost?",
    a: "No. That is the whole point. Instead of charging you thousands upfront like most web designers, everything is rolled into one simple monthly rate.",
  },
];
---

<section id="faq" class="sec-pad band">
  <div class="container container-md">
    <div class="section-head" data-reveal>
      <span class="eyebrow"><span class="num">// 06</span> FAQ</span>
      <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="none" weight="fw700">
        Questions people always ask.
      </Heading>
    </div>

    <div class="faq-list" data-reveal>
      {
        faqs.map((item, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>
              <span class="faq-index">{String(i + 1).padStart(2, "0")}</span>
              <span class="faq-q">{item.q}</span>
              <span class="faq-plus" aria-hidden="true" />
            </summary>
            <div class="faq-a">
              <p>{item.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--_spacing---space--4);
    max-width: 940px;
    margin-top: var(--_spacing---section-space--small);
  }

  .faq-item {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--surface-primary);
    overflow: hidden;
    transition: border-color var(--dur) var(--ease-out);

    &:hover {
      border-color: var(--lime-deep);
    }
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    gap: var(--_spacing---space--6);
    padding: var(--_spacing---space--7) var(--_spacing---space--7);
    cursor: pointer;
    list-style: none;
    outline: none;

    &::-webkit-details-marker {
      display: none;
    }
  }

  .faq-index {
    flex: none;
    width: 2.2ch;
    font-weight: 700;
    font-size: var(--_typography---font-size--mono-sm);
    line-height: 1;
    font-family: var(--mono-family);
    letter-spacing: 0.1em;
    color: var(--tangerine);
  }

  .faq-q {
    flex: 1;
    font-weight: 700;
    font-size: var(--_typography---font-size--text-large);
    line-height: 1.3;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    color: var(--fg1);
  }

  .faq-plus {
    position: relative;
    flex: none;
    width: 38px;
    height: 38px;
    border: 2px solid var(--ink-900);
    border-radius: 50%;
    background: var(--lime);
    outline: none;
    transition: background var(--dur) var(--ease-out);

    &::before,
    &::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      width: 14px;
      height: 2px;
      background: var(--ink-900);
      transform: translate(-50%, -50%);
      transition: transform var(--dur) var(--ease-out), opacity var(--dur) var(--ease-out);
    }

    &::after {
      transform: translate(-50%, -50%) rotate(90deg);
    }
  }

  .faq-item[open] .faq-plus::after {
    transform: translate(-50%, -50%) rotate(0deg);
    opacity: 0;
  }

  .faq-a {
    border-top: 1px solid var(--border-color);
    padding: var(--_spacing---space--7) var(--_spacing---space--7);
    padding-left: calc(var(--_spacing---space--7) + 2.2ch + var(--_spacing---space--6));

    p {
      margin: 0;
      max-width: 68ch;
      font-weight: 400;
      font-size: var(--_typography---font-size--text-main);
      line-height: 1.65;
      font-family: var(--font-body);
      color: var(--fg2);
    }
  }
</style>
