---
// COMPONENTS
import Heading from "@/components/Heading.astro";

// HELPERS
import { Image } from "astro:assets";

// IMAGES
import chrisComputer from "@/assets/chris-computer.png";

const milestones = [
  {
    year: "2016",
    title: "Where it started",
    body: "I started doing design work in 2016. Beyond Belief was born the same year, as something else entirely. A screen printing studio, a side project and a creative escape from the digital world I worked in all day. I loved the analog side of it. The ink, the print, the hands-on work.",
  },
  {
    year: "2018",
    title: "Going full-time",
    body: "I went full-time as a graphic and web designer in 2018, building for every kind of business you can imagine.",
  },
  {
    year: "2020",
    title: "Everything clicked",
    body: "By 2020 I had narrowed my focus entirely to web design and development. That is when everything really clicked. My design, development, and SEO skills took off, and I have been deep in it every day since. Well over 200 websites later, that experience taught me what actually works: what makes a site rank, what makes a visitor trust you, and what turns that visitor into a paying customer.",
  },
  {
    year: "2025",
    title: "What it was always meant to be",
    body: "Over time my passion for web design outgrew everything else. I realized I had something real to offer the businesses around me, and I wanted a way to focus on it fully and get more involved in my own community. So in 2025, Beyond Belief became what it was always meant to be: a web design studio built to help local businesses grow.",
  },
];
---

<section id="story" class="sec-pad sec-dark">
  <div class="container container-md">
    <div class="story-grid">
      <aside class="story-aside" data-reveal>
        <span class="eyebrow"><span class="num">// 02</span> How I got here</span>
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="m" weight="fw700">
          A decade of design. One clear focus.
        </Heading>
        <div class="story-stat">
          <span class="stat-num"><span data-count="200">200</span>+</span>
          <span class="stat-label">websites built professionally, and counting</span>
        </div>
        <div class="story-photo">
          <Image src={chrisComputer} alt="Chris at work" widths={[420, 840]} />
          <div class="story-cap"><span>Deep in it, every day</span><span class="st">✦</span></div>
        </div>
      </aside>

      <div class="story-feed">
        {
          milestones.map(m => (
            <div class="ms-item" data-reveal>
              <span class="ms-year">{m.year}</span>
              <div class="ms-content">
                <Heading tag="h3" size="s" fontFamily="primary" marginBottom="s" weight="fw700">
                  {m.title}
                </Heading>
                <p>{m.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .story-grid {
    display: grid;
    grid-template-columns: 0.88fr 1.12fr;
    gap: var(--_spacing---section-space--large);
    align-items: start;
  }

  .story-aside {
    position: sticky;
    top: calc(var(--nav-height, 90px) + var(--_spacing---space--8));
  }

  .story-stat {
    margin: var(--_spacing---space--3) 0 var(--_spacing---space--8);
  }

  .stat-num {
    display: block;
    font-weight: 800;
    font-size: clamp(3rem, 5vw, 4.4rem);
    line-height: 1;
    font-family: var(--font-display);
    letter-spacing: var(--track-display);
    color: var(--lime);
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    display: block;
    max-width: 26ch;
    margin-top: var(--_spacing---space--3);
    font-size: var(--_typography---font-size--text-small);
    line-height: 1.5;
    font-family: var(--font-body);
    color: var(--stone-300);
  }

  .story-photo {
    overflow: hidden;
    border: 1px solid var(--ink-600);
    border-radius: var(--radius-lg);
    box-shadow: 0 40px 90px -38px rgba(0, 0, 0, 0.6);

    :global(img) {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      filter: saturate(0.9);
    }
  }

  .story-cap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--_spacing---space--5) var(--_spacing---space--6);
    font-weight: 700;
    font-size: var(--_typography---font-size--label);
    line-height: 1;
    font-family: var(--mono-family);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--stone-400);
    background: var(--ink-800);

    .st {
      color: var(--lime);
    }
  }

  .story-feed {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--ink-600);
  }

  .ms-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--_spacing---section-space--small);
    align-items: start;
    padding: var(--_spacing---section-space--small) 0;
    border-bottom: 1px solid var(--ink-600);
  }

  .ms-year {
    padding-top: var(--_spacing---space--3);
    font-weight: 800;
    font-size: var(--_typography---font-size--text-large);
    line-height: 1;
    font-family: var(--font-display);
    letter-spacing: var(--track-tight);
    color: var(--lime);
  }

  .ms-content p {
    max-width: 62ch;
    font-size: var(--_typography---font-size--text-main);
    line-height: 1.6;
    font-family: var(--font-body);
    color: var(--stone-300);
  }

  @media (max-width: 900px) {
    .story-grid {
      grid-template-columns: 1fr;
    }

    .story-aside {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .ms-item {
      grid-template-columns: 64px 1fr;
    }
  }
</style>
