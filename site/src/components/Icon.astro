---
// Inline line-icon set. 24×24 grid, stroke-1.8, round caps/joins, currentColor.
// Usage: <Icon name="pin" /> — size via prop or via context CSS (e.g. .icon-box svg).

// PROPS
interface Props {
  name: string;
  size?: number;
  class?: string;
  title?: string;
}
const { name, size = 24, class: className, title } = Astro.props;

const icons: Record<string, string> = {
  // </> custom code
  code: '<path d="m8 8-4 4 4 4"/><path d="m16 8 4 4-4 4"/>',
  // lightning — speed
  bolt: '<path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/>',
  // map pin — local
  pin: '<path d="M12 21s7-6.3 7-11a7 7 0 1 0-14 0c0 4.7 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  // magnifier + rising line — rank on Google
  "search-rank":
    '<circle cx="10.5" cy="10.5" r="6.5"/><path d="m20 20-5.2-5.2"/><path d="M7.6 12l2-2.3 1.7 1.5 2.6-3"/>',
  // bar chart + up arrow — convert/leads
  "bar-up": '<path d="M5 20v-5"/><path d="M11 20V9"/><path d="M17 20V5"/><path d="M14.5 7.5 17 5l2.5 2.5"/>',
  // burst — stand out
  burst: '<path d="M12 3v18"/><path d="M3 12h18"/><path d="m6 6 12 12"/><path d="m18 6-12 12"/>',
  // browser window — five pages
  window: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><path d="M6.5 7h.01"/>',
  // stacked racks — hosting
  server:
    '<rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><path d="M6.5 7.5h.01"/><path d="M6.5 16.5h.01"/>',
  // refresh arrows — updates
  refresh: '<path d="M20 11a8 8 0 1 0-2.3 5.7"/><path d="M20 5v6h-6"/>',
  // phone outline — mobile
  phone: '<rect x="6.5" y="2.5" width="11" height="19" rx="2.5"/><path d="M11 18.5h2"/>',
  // speech bubble — support
  message:
    '<path d="M21 11.5a7.5 7.5 0 0 1-10.8 6.7L4 20l1.8-5.2A7.5 7.5 0 1 1 21 11.5Z"/><path d="M8.5 10.5h7"/><path d="M8.5 13.5h4"/>',
  // shield + check — trust
  shield: '<path d="M12 3 5 6v5c0 4.3 3 7.5 7 9 4-1.5 7-4.7 7-9V6l-7-3Z"/><path d="m9 11.5 2 2 4-4"/>',
  // line chart up — grow
  grow: '<path d="M4 19h16"/><path d="M5 16l4-5 3.5 3L19 7"/><path d="M15.5 7H19v3.5"/>',
  // → arrow
  arrow: '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
};

const inner = icons[name] ?? "";
const a11y = title
  ? { role: "img", "aria-label": title }
  : { "aria-hidden": "true", role: "presentation" };
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  {...a11y}
  set:html={inner}
></svg>
