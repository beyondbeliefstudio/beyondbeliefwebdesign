---
// COMPONENTS
import Icon from "@/components/Icon.astro";
---

<section id="trust">
  <div class="container container-full">
    <div class="trust-grid">
      <div class="item">
        <span class="ic"><Icon name="code" /></span>
        <span class="t">100% custom, no templates ever</span>
      </div>
      <div class="item">
        <span class="ic"><Icon name="bolt" /></span>
        <span class="t">Sites that load in under a second</span>
      </div>
      <div class="item">
        <span class="ic"><Icon name="pin" /></span>
        <span class="t">Proudly based in Monroe, NC</span>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  #trust {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .trust-grid .item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--_spacing---space--6);
    padding: var(--_spacing---space--8) var(--_spacing---space--7);
  }
  .trust-grid .item + .item {
    border-left: 1px solid var(--border);
  }
  .trust-grid .ic {
    flex: none;
    width: 22px;
    height: 22px;
    color: var(--lime-deep);
  }
  .trust-grid .ic :global(svg) {
    width: 100%;
    height: 100%;
  }
  .trust-grid .t {
    font: 600 15px/1.3 var(--font-body);
    color: var(--fg1);
  }
  @media (max-width: 860px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }
    .trust-grid .item + .item {
      border-left: 0;
      border-top: 1px solid var(--border);
    }
    .trust-grid .item {
      padding: var(--_spacing---space--7) var(--_spacing---space--3);
    }
  }
</style>
