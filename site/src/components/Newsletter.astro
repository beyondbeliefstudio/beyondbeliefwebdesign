---
// Recurring dark newsletter band (blog landing + blog post).
import Heading from "@/components/Heading.astro";
---

<section id="subscribe" class="sec-pad sec-dark">
  <span class="sub-glow" aria-hidden="true"></span>
  <div class="container container-md">
    <div class="sub-grid">
      <div class="sub-left" data-reveal>
        <span class="eyebrow"><span class="dot"></span>Straight to your inbox</span>
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="s" weight="fw700">
          Want this kind of advice without digging through Google?
        </Heading>
        <p class="sub-body">
          I write about the stuff local business owners actually need to know. No spam, no nonsense,
          just useful things, now and then.
        </p>
      </div>

      <div class="sub-right" data-reveal>
        <form
          class="sub-form"
          data-netlify="true"
          netlify-honeypot="bot-field"
          name="newsletter"
          method="POST"
          action="/submit-contact"
        >
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>
          <label class="sr-only" for="news-email">Your email</label>
          <input type="email" id="news-email" name="email" placeholder="you@example.com" required />
          <button type="submit" class="btn primary">Subscribe <span class="arr" aria-hidden="true">→</span></button>
        </form>
        <p class="sub-note">✦ Unsubscribe anytime. I'll never sell your email.</p>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  #subscribe {
    position: relative;
    overflow: hidden;
  }
  .sub-glow {
    position: absolute;
    inset: auto 0 -20% auto;
    width: 620px;
    height: 460px;
    pointer-events: none;
    background: radial-gradient(620px 460px at 82% 120%, rgba(204, 255, 0, 0.16), transparent 62%);
  }
  .sub-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 0.92fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: center;
  }
  .sub-body {
    max-width: 46ch;
    font: 400 1.0625rem/1.6 var(--font-body);
    color: var(--stone-200);
  }
  .sub-form {
    flex-direction: row;
    gap: 10px;

    input {
      flex: 1;
      padding: 16px 22px;
      font: 400 1rem/1 var(--font-body);
      color: var(--paper);
      background: rgba(255, 255, 255, 0.04);
      border: 1.5px solid var(--ink-600);
      border-radius: var(--radius-pill);
      outline: none;
      transition: border-color var(--dur), box-shadow var(--dur);

      &::placeholder {
        color: var(--stone-400);
      }
      &:focus {
        border-color: var(--lime-deep);
        box-shadow: 0 0 0 3px var(--lime-wash);
      }
    }
    .btn {
      flex: none;
    }
  }
  .sub-note {
    margin-top: 14px;
    font: 400 0.8rem/1.5 var(--font-body);
    color: var(--stone-400);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  @media (max-width: 820px) {
    .sub-grid {
      grid-template-columns: 1fr;
    }
    .sub-form {
      flex-direction: column;
      align-items: stretch;

      .btn {
        justify-content: center;
      }
    }
  }
</style>
